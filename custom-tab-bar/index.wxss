.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: 138rpx;
  padding: 12rpx 56rpx 22rpx;
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -8rpx 24rpx rgba(28, 24, 24, 0.05);
}

.tab-item {
  width: 180rpx;
  height: 98rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #c7c3c3;
  font-size: 25rpx;
  font-weight: 800;
}

.tab-item.active {
  color: #171313;
}

.tab-icon {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 8rpx;
}

.tab-icon.photo::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 8rpx;
  width: 34rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 4rpx;
}

.tab-icon.photo::after {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 15rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
}

.tab-icon.time::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 4rpx;
  width: 4rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-icon.time::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 12rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  background: #fff;
}
